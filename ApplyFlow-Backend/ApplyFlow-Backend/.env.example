# Backend environment variables
# Use these values in your hosting provider's environment settings.
# .NET maps double underscores to nested configuration keys.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# PostgreSQL connection string
ConnectionStrings__DefaultConnection=Host=YOUR_DB_HOST;Port=5432;Database=applyflow;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT settings
# Jwt__Key must be at least 32 characters long.
Jwt__Key=replace-with-a-strong-32-plus-character-secret
Jwt__Issuer=ApplyFlow
Jwt__Audience=ApplyFlow
Jwt__ExpiresInMinutes=60

